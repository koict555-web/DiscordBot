@bot.event
async def on_ready():
    print(f"✅ บอท {bot.user.name} ออนไลน์แล้ว!")
    if not check_system_status.is_running():
        check_system_status.start()
    if not send_heartbeat.is_running():
        send_heartbeat.start()

@bot.event
async def on_message(message):
    if message.author == bot.user: return
    if message.channel.id == VERIFY_CHANNEL_ID and message.attachments:
        for attachment in message.attachments:
            if any(attachment.filename.lower().endswith(ext) for ext in ['png', 'jpg', 'jpeg']):
                msg = await message.reply("⏳ กำลังตรวจสอบสลิป...")
                success, result = verify_slip2go(attachment.url)
                if success:
                    amount = result['amount']
                    trans_ref = result['trans_ref']
                    used_slips = sheet.col_values(4)
                    if trans_ref and trans_ref in used_slips:
                        await msg.edit(content=f"🚫 **สลิปนี้ใช้ไปแล้ว!** (Ref: {trans_ref})")
                        return
                    if amount in PRICE_CONFIG:
                        days = PRICE_CONFIG[amount]
                        role = message.guild.get_role(ROLE_ID)
                        if role: await message.author.add_roles(role)
                        new_key = generate_random_key()
                        expire_date = (datetime.now() + timedelta(days=days)).strftime("%Y-%m-%d %H:%M:%S")
                        sheet.append_row([new_key, "", expire_date, trans_ref])
                        embed = discord.Embed(title="✅ ชำระเงินสำเร็จ!", color=0x2ecc71)
                        embed.add_field(name="🔑 คีย์", value=f"||{new_key}||")
                        embed.set_footer(text=f"Expire: {expire_date}")
                        await msg.edit(content=None, embed=embed)
                        try: await message.author.send(f"🔑 คีย์ของคุณ: `{new_key}` หมดอายุ: `{expire_date}`")
                        except: await message.channel.send(f"⚠️ {message.author.mention} บอทส่ง DM ไม่ได้!")
                    else:
                        await msg.edit(content=f"❌ ยอด {amount} ไม่ตรงแพ็กเกจ")
                else:
                    await msg.edit(content=f"❌ {result}")
    await bot.process_commands(message)

