def generate_random_key():
    parts = [''.join(random.choices(string.ascii_uppercase + string.digits, k=4)) for _ in range(3)]
    return '-'.join(parts)

def verify_slip2go(image_url):
    url = "https://connect.slip2go.com/api/verify-slip/qr-code/info"
    headers = {
        "Authorization": f"Bearer {SLIP2GO_SECRET_KEY}",
        "Content-Type": "application/json"
    }
    try:
        resp = requests.get(image_url)
        image_bytes = np.asarray(bytearray(resp.content), dtype="uint8")
        image = cv2.imdecode(image_bytes, cv2.IMREAD_COLOR)
        decoded_objects = decode(image)
        if not decoded_objects:
            return False, "ไม่พบ QR Code ในสลิป"
        qr_text = decoded_objects[0].data.decode('utf-8')
        data_payload = {"payload": {"qrCode": qr_text}}
        response = requests.post(url, headers=headers, json=data_payload)
        result = response.json()
        if response.status_code == 200:
            data_part = result.get("data", result)
            if isinstance(data_part, str):
                data_part = json.loads(data_part)
            return True, {"amount": float(data_part.get("amount", 0)), "trans_ref": data_part.get("transRef", "")}
        return False, result.get("message", "ตรวจสอบข้อมูลไม่ได้")
    except Exception as e:
        return False, f"ข้อผิดพลาด: {str(e)}"

