    await bot.wait_until_ready()
    status_db, status_api = "🟢", "🟢"
    try:
        sheet.row_values(1)
    except:
        status_db = "🔴"
    try:
        r = requests.get("https://connect.slip2go.com/", timeout=5)
        if r.status_code != 200: status_api = "🔴"
    except:
        status_api = "🔴"
    
    full_status = f"System: DB{status_db} | API{status_api}"
    await bot.change_presence(activity=discord.Activity(type=discord.ActivityType.watching, name=full_status))
    
    channel = bot.get_channel(STATUS_CHANNEL_ID)
    if channel:
        try: await channel.edit(name=f"สถานะระบบ-{status_db}{status_api}")
        except: pass

